rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Admins have full access to everything in the database
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'starltd49@gmail.com' ||
        request.auth.token.email == '93151f5941@gmail.com' ||
        request.auth.token.email == 'admin@alsafar.com'
      );
    }

    // Is the user requesting for their own document?
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    // 2. Packages Collection
    match /packages/{packageId} {
      allow read: if true; // Public can view packages
      allow write: if isAdmin(); // Only admins can create/update packages
    }

    // 3. Bookings Collection
    match /bookings/{bookingId} {
      allow read, get, list: if isAdmin() || (isSignedIn() && (
        resource.data.get('contactEmail', '') == request.auth.token.email ||
        resource.data.get('contactEmail', '').lower() == request.auth.token.email.lower()
      ));
      allow create: if isSignedIn(); // Logged-in clients can create bookings
      allow update, delete: if isAdmin(); // Only admins can cancel/confirm bookings
    }

    // 4. Customers Collection -> Registered customer profiles
    match /customers/{customerId} {
      allow read: if isAdmin() || isOwner(customerId);
      allow write: if isAdmin() || isOwner(customerId);
    }

    // 5. Orders Collection -> Financial documents
    match /orders/{orderId} {
      allow read, get, list: if isAdmin() || (isSignedIn() && (
        resource.data.get('customerEmail', '') == request.auth.token.email ||
        resource.data.get('customerEmail', '').lower() == request.auth.token.email.lower()
      ));
      allow write: if isAdmin();
    }

    // 6. Inquiries Collection -> Forms sent by users
    match /inquiries/{inquiryId} {
      allow read, get, list: if isAdmin() || (isSignedIn() && (
        resource.data.get('email', '') == request.auth.token.email ||
        resource.data.get('email', '').lower() == request.auth.token.email.lower()
      ));
      allow create: if true; // Anyone can submit a contact form/inquiry
      allow update, delete: if isAdmin();
    }

    // 7. Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true; // Anyone can read approved reviews
      allow create: if isSignedIn(); // Logged-in users can write a review
      allow update, delete: if isAdmin();
    }

    // 8. Gallery Collection
    match /gallery/{galleryId} {
      allow read: if true; // Public can view gallery
      allow write: if isAdmin();
    }

    // 9. Blog posts
    match /blog_posts/{postId} {
      allow read: if true; // Public can read blog posts
      allow write: if isAdmin();
    }

    // 10. Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true; // Public can read testimonials
      allow write: if isAdmin();
    }

    // 11. Notifications
    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || isSignedIn(); // System/clients might place notifications
    }

    // 12. Settings
    match /settings/{settingsId} {
      allow read: if true; // App needs to load contact/agency settings
      allow write: if isAdmin();
    }
  }
}
